<%- include('../partials/header') %>

<div class="max-w-md mx-auto mt-10 bg-neon-card p-8 rounded-xl neon-glow">
    <h2 class="text-3xl font-bold text-center text-neon-pink mb-6">Join NeonStrike</h2>
    <form action="/signup" method="post" class="space-y-5">
        <div>
            <label class="block text-gray-400 text-sm mb-1">Username</label>
            <input type="text" name="username" required 
                   class="w-full px-4 py-2 bg-neon-bg border border-gray-600 rounded-lg focus:outline-none focus:border-neon-pink text-white" 
                   placeholder="CyberNinja99">
        </div>
        <div>
            <label class="block text-gray-400 text-sm mb-1">Email Address</label>
            <input type="email" name="email" required 
                   class="w-full px-4 py-2 bg-neon-bg border border-gray-600 rounded-lg focus:outline-none focus:border-neon-pink text-white" 
                   placeholder="player@neonstrike.com">
        </div>
        <div>
            <label class="block text-gray-400 text-sm mb-1">Password</label>
            <input type="password" name="password" required 
                   class="w-full px-4 py-2 bg-neon-bg border border-gray-600 rounded-lg focus:outline-none focus:border-neon-pink text-white" 
                   placeholder="••••••••">
        </div>
        <button type="submit" class="w-full py-3 bg-neon-pink hover:bg-pink-400 text-neon-bg font-bold rounded-lg transition transform hover:scale-105">
            Create Account
        </button>
    </form>
    <p class="text-center text-gray-400 mt-6 text-sm">
        Already a player? <a href="/login" class="text-neon-accent hover:underline">Login here</a>
    </p>
</div>

<%- include('../partials/footer') %>