<%- include('partials/header') %>

<div class="mb-8 text-center">
    <h1 class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-neon-accent to-neon-pink">
        Live Leaderboard
    </h1>
    <p class="text-gray-400 mt-2">Top players dominating the NeonStrike arena right now.</p>
</div>

<!-- Leaderboard Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (locals.users && users.length > 0) { %>
        <% users.forEach(function(user, index) { %>
            <div class="bg-neon-card border border-gray-700 rounded-xl p-6 hover:border-neon-accent transition-all duration-300 transform hover:-translate-y-1 shadow-lg">
                
                <!-- Header: Rank & Avatar -->
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <!-- Rank Badge -->
                        <div class="text-2xl font-bold 
                            <%= index === 0 ? 'text-yellow-400' : (index === 1 ? 'text-gray-300' : (index === 2 ? 'text-amber-600' : 'text-gray-500')) %>">
                            #<%= index + 1 %>
                        </div>
                        <!-- Avatar Placeholder -->
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-neon-accent to-neon-pink flex items-center justify-center text-neon-bg font-bold text-xl">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                    </div>
                    <h3 class="text-xl font-bold text-white truncate"><%= user.username %></h3>
                </div>

                <!-- Stats -->
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-neon-bg p-3 rounded-lg text-center">
                        <p class="text-xs text-gray-400 uppercase tracking-wide">Score</p>
                        <p class="text-2xl font-bold text-neon-accent"><%= user.score %></p>
                    </div>
                    <div class="bg-neon-bg p-3 rounded-lg text-center">
                        <p class="text-xs text-gray-400 uppercase tracking-wide">Profile Views</p>
                        <p class="text-2xl font-bold text-neon-pink"><%= user.views %></p>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex space-x-3">
                    <!-- View Profile Form (POST to increment views) -->
                    <form action="/newUsers/user/<%= user.id %>/view" method="POST" class="flex-1">
                        <button type="submit" class="w-full py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm font-medium transition flex items-center justify-center space-x-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                            <span>View</span>
                        </button>
                    </form>

                    <!-- Add Score Form (POST to increment score) -->
                    <form action="/user/<%= user.id %>/score" method="POST" class="flex-1">
                        <button type="submit" class="w-full py-2 bg-neon-accent hover:bg-blue-400 text-neon-bg rounded-lg text-sm font-bold transition flex items-center justify-center space-x-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                            <span>Add Score</span>
                        </button>
                    </form>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-span-full text-center py-20 text-gray-500">
            <p class="text-xl">The arena is empty. Be the first to strike!</p>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>